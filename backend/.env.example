# Optional Gemini API key
# GEMINI_API_KEY=your_gemini_key_here

# Flask settings
FLASK_PORT=5000
FLASK_DEBUG=true
SECRET_KEY=nexus-super-secret-key-change-in-production

# ============================================================
# MSSQL Connection String — update with your server details
# ============================================================
# Option 1: Windows Authentication (no username/password needed)
MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=nexus;Trusted_Connection=yes;TrustServerCertificate=yes;

# Option 2: SQL Authentication (username + password)
# MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=nexus;UID=your_username;PWD=your_password;TrustServerCertificate=yes;
